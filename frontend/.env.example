# Network (testnet or mainnet)
VITE_NETWORK=testnet

# Use PLONK LogicSig verification (cheaper than Groth16)
VITE_USE_PLONK_LSIG=true

# WalletConnect v2 project ID — get one at https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=

# Optional: override default relayer URLs and addresses (for self-hosted relayers)
# VITE_RELAYER_1_URL=https://your-relayer-1.workers.dev
# VITE_RELAYER_1_ADDRESS=YOUR_RELAYER_1_ALGORAND_ADDRESS
# VITE_RELAYER_2_URL=https://your-relayer-2.workers.dev
# VITE_RELAYER_2_ADDRESS=YOUR_RELAYER_2_ALGORAND_ADDRESS
