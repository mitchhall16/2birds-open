{
  "name": "@2birds/circuits",
  "version": "0.1.0",
  "description": "Compiled Circom circuits, proving keys, and WASM witness generators for Algorand privacy SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
